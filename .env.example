# CTRLD Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an

# ── PFLICHTFELD ──────────────────────────────────────────────────────────────
# JWT-Secret: Mindestens 32 zufällige Zeichen
# Generieren: openssl rand -hex 32
CTRLD_SECURITY_JWT_SECRET=HIER-ZUFAELLIGES-SECRET-MIN-32-ZEICHEN-EINSETZEN

# ── Optional ──────────────────────────────────────────────────────────────────
# Log-Level: trace / debug / info / warn / error
CTRLD_LOG_LEVEL=info

# Port für Backend API (Standard: 8443)
CTRLD_PORT=8443

# Port für Frontend (Standard: 3000)
NEXT_PORT=3000
